{
  "name": "the-garbage-collector",
  "productName": "The Garbage Collector",
  "private": true,
  "version": "0.2.1",
  "description": "A silent pixel-art RPG that teaches real C (CS1160-style) — four floors, Labs 1-11.",
  "author": "MKultra-608",
  "license": "MIT",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:demo": "node scripts/make-demo.cjs",
    "build:itch": "node scripts/make-itch-zip.cjs",
    "app:renderer": "node scripts/build-renderer.cjs",
    "start": "npm run app:renderer && electron .",
    "dist": "node scripts/make-icon.cjs && npm run app:renderer && electron-builder --dir && node scripts/make-installer.cjs",
    "installer": "node scripts/make-installer.cjs",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-transform-types tests/interp.test.ts && node --experimental-transform-types tests/content.test.ts && node --experimental-transform-types tests/solutions.test.ts"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.mkultra608.garbagecollector",
    "productName": "The Garbage Collector",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "files": [
      "electron/**",
      "dist/**",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Garbage Collector",
      "artifactName": "TheGarbageCollector-Setup-${version}.${ext}"
    }
  }
}
